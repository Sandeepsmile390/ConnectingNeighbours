{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/api-server/src/app.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "lib/**",
          "node_modules/**"
        ]
      }
    },
    {
      "src": "artifacts/connecting-neighbors/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/src/app.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/connecting-neighbors/$1"
    }
  ]
}
